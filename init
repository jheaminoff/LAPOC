#!/usr/bin/env bash
set -euo pipefail

# ============================================================ #
# LAPOC — LA City Planning One-Stop-Shop  Bootstrap Script
# ============================================================ #
# Usage:  bash init
#         bash init --fast    (skip reinstall if deps present)
# ============================================================ #

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FAST="${2:-}"
PYTHON="${PYTHON:-python3}"

echo "━━━ LAPOC Bootstrap ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# ----------------------------------------------------------- #
# 1. Backend
# ----------------------------------------------------------- #
echo "→ Backend setup ($ROOT/backend)"

cd "$ROOT/backend"

# Virtual environment
if [ ! -d "$ROOT/.venv" ]; then
  echo "  Creating Python virtual environment (.venv) …"
  $PYTHON -m venv "$ROOT/.venv"
else
  echo "  ✓ .venv exists"
fi
source "$ROOT/.venv/bin/activate"

# Dependencies
if [ "$FAST" != "--fast" ] || [ ! -f "$ROOT/.venv/.deps-installed" ]; then
  echo "  Installing Python dependencies …"
  pip install -q -r requirements.txt
  date > "$ROOT/.venv/.deps-installed"
  echo "  ✓ Dependencies installed"
else
  echo "  ✓ Dependencies already installed (--fast)"
fi

# .env file
if [ ! -f ".env" ]; then
  cp .env.example .env
  echo "  ⚠  Created .env from .env.example — edit with your Azure OpenAI credentials"
else
  echo "  ✓ .env exists"
fi

# Seed database
echo "  Seeding database …"
$PYTHON seed/seed_data.py

echo ""
echo "  ✓ Backend ready"
echo "    Start:  cd backend && uvicorn main:app --reload"
echo "    Docs:   http://localhost:8000/docs"
echo ""

# ----------------------------------------------------------- #
# 2. Frontend
# ----------------------------------------------------------- #
echo "→ Frontend setup ($ROOT/frontend)"

cd "$ROOT/frontend"

if [ "$FAST" != "--fast" ] || [ ! -d "node_modules" ]; then
  echo "  Installing Node.js dependencies …"
  npm install
  echo "  ✓ Dependencies installed"
else
  echo "  ✓ node_modules exists (--fast)"
fi

echo ""
echo "  ✓ Frontend ready"
echo "    Start:  cd frontend && npm run dev"
echo "    Open:   http://localhost:5173"
echo ""

# ----------------------------------------------------------- #
# 3. Summary
# ----------------------------------------------------------- #
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "  Backend :  uvicorn main:app --reload       (port 8000)"
echo "  Frontend:  npm run dev                     (port 5173)"
echo "  DB     :   $ROOT/lapoc.db"
echo "  Env   :   $ROOT/backend/.env"
echo ""
echo "  First time?   Set AZURE_OPENAI_* vars in backend/.env"
echo "  Reseed DB?    cd backend && python seed/seed_data.py"
echo "  Verify?       open http://localhost:8000/docs"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
